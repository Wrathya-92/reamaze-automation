# Reamaze
REAMAZE_API_TOKEN=your_reamaze_api_token
REAMAZE_BRAND=your_brand_slug
REAMAZE_EMAIL=your_reamaze_login_email
REAMAZE_WEBHOOK_SECRET=your_webhook_secret

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server
PORT=3000

# Business Hours (America/Bogota = UTC-5)
BUSINESS_HOURS_START=11
BUSINESS_HOURS_END=19
TIMEZONE=America/Bogota

# Response Mode: "review" = queue for human review, "auto" = send automatically
TIER2_MODE=review

# Trust threshold to suggest switching to auto mode (0-100)
TRUST_THRESHOLD=98
